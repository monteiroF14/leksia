---
import Layout from '@/layouts/Layout.astro';
---

<Layout>
  <div class="max-w-7xl mx-auto"> 
    <h1 class="text-4xl font-bold text-gray-900 mb-8">frase explicativa sobre a app e dislexia</h1>
    
    <div class="rounded-xl mb-8 space-y-4">
      <div>
        <label for="wiki-url" class="block text-sm font-semibold text-gray-700 mb-2">
          Enter Wikipedia URL
        </label>
        <div class="flex gap-3">
          <input
            type="text"
            id="wiki-url"
            placeholder="https://en.wikipedia.org/wiki/..."
            class="flex-1 px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-gray-500 outline-none transition bg-gray-50"
          />
          <button
            id="fetch-btn"
            class="p-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="flex-1 h-px bg-gray-300"></div>
        <span class="text-sm text-gray-500 font-medium">OR</span>
        <div class="flex-1 h-px bg-gray-300"></div>
      </div>

      <div>
        <label for="pdf-file" class="block text-sm font-semibold text-gray-700 mb-2">
          Upload a PDF
        </label>
        <div class="flex gap-3">
          <input
            type="file"
            id="pdf-file"
            accept=".pdf"
            class="flex-1 px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-gray-500 outline-none transition bg-gray-50 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-gray-900 file:text-white hover:file:bg-gray-800"
          />
          <button
            id="pdf-btn"
            class="p-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="flex-1 h-px bg-gray-300"></div>
        <span class="text-sm text-gray-500 font-medium">OR</span>
        <div class="flex-1 h-px bg-gray-300"></div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">
          Speech Recognition
        </label>
        <div class="flex gap-3 items-center">
          <button
            id="speech-play-btn"
            class="flex-1 p-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition shadow-md disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
            <span>Start Listening</span>
          </button>
          <button
            id="speech-stop-btn"
            class="flex-1 p-3 bg-red-600 text-white rounded-lg hover:bg-red-700 focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition shadow-md disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
            disabled
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="6" width="12" height="12"/>
            </svg>
            <span>Stop</span>
          </button>
        </div>
      </div>

      <div id="speech-output" class="hidden p-4 bg-gray-100 rounded-lg border border-gray-200">
        <p class="text-sm font-semibold text-gray-600 mb-1">You said:</p>
        <p id="speech-text" class="text-gray-900"></p>
      </div>

      <p id="error-msg" class="mt-2 text-sm text-red-600 hidden"></p>
    </div>

    <div id="loading" class="hidden flex justify-center py-12">
      <div class="animate-spin rounded-full h-12 w-12 border-4 border-gray-600 border-t-transparent"></div>
    </div>

    <div id="content" class="hidden">
      <div class="rounded-xl overflow-hidden">
        <div class="px-8 py-6 bg-gray-900">
          <h2 id="content-title" class="text-3xl font-bold text-white underline"></h2>
          <p id="content-description" class="text-gray-300 mt-2 text-sm"></p>
        </div>
        <div id="content-body" class="p-8 prose prose-gray max-w-none"></div>
      </div>
      
      <div id="wiki-infobox" class="hidden bg-white rounded-xl shadow-lg overflow-hidden border border-gray-100 mt-6">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
          <h3 id="infobox-title" class="text-lg font-bold text-gray-900"></h3>
        </div>
        <div id="infobox-content" class="p-6"></div>
      </div>
    </div>
  </div>
</Layout>

<script type="module">
  import { getDocument, GlobalWorkerOptions } from 'pdfjs-dist';

  GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.10.38/pdf.worker.min.mjs';

  const input = document.getElementById('wiki-url');
  const btn = document.getElementById('fetch-btn');
  const pdfInput = document.getElementById('pdf-file');
  const pdfBtn = document.getElementById('pdf-btn');
  const content = document.getElementById('content');
  const contentTitle = document.getElementById('content-title');
  const contentDescription = document.getElementById('content-description');
  const contentBody = document.getElementById('content-body');
  const error = document.getElementById('error-msg');
  const loading = document.getElementById('loading');
  const speechPlayBtn = document.getElementById('speech-play-btn');
  const speechStopBtn = document.getElementById('speech-stop-btn');
  const speechOutput = document.getElementById('speech-output');
  const speechText = document.getElementById('speech-text');

  console.log('Script loaded');

  let speechRecognition = null;
  const SpeechRecognitionAPI = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (SpeechRecognitionAPI) {
    speechRecognition = new SpeechRecognitionAPI();
    speechRecognition.lang = 'en-US';
    speechRecognition.continuous = true;
    speechRecognition.interimResults = false;
    speechRecognition.onresult = (event) => {
      const transcript = event.results[0][0].transcript;
      console.log('You said:', transcript);
      if (speechText) speechText.textContent = transcript;
      if (speechOutput) speechOutput.classList.remove('hidden');
    };
    speechRecognition.onerror = (event) => {
      console.error('Speech recognition error:', event.error);
      showError(`Speech recognition error: ${event.error}`);
    };
  }

  function isWikipediaUrl(url) {
    return url.match(/^https?:\/\/([a-z]{2}\.)?wikipedia\.org\/wiki\/.+/i);
  }

  function extractPageTitle(url) {
    const match = url.match(/wikipedia\.org\/wiki\/([^?#]+)/i);
    if (match) {
      return decodeURIComponent(match[1].replace(/_/g, ' '));
    }
    return '';
  }

  function extractLanguage(url) {
    const match = url.match(/^https?:\/\/([a-z]{2})\./i);
    return match ? match[1] : 'en';
  }

  async function fetchWikiContent() {
    const url = input.value.trim();
    
    if (!url) {
      showError('Please enter a URL');
      return;
    }

    if (!isWikipediaUrl(url)) {
      showError('Please enter a valid Wikipedia URL');
      return;
    }

    const pageTitle = extractPageTitle(url);
    const lang = extractLanguage(url);
    
    if (!pageTitle) {
      showError('Could not extract page title from URL');
      return;
    }

    hideError();
    content?.classList.add('hidden');
    loading?.classList.remove('hidden');
    btn.disabled = true;

    try {
      const apiUrl = `/api/wiki?title=${encodeURIComponent(pageTitle)}&lang=${lang}`;
      const response = await fetch(apiUrl);
      
      if (!response.ok) {
        throw new Error('Page not found');
      }

      const data = await response.json();
      
      if (contentTitle) contentTitle.textContent = data.parse?.title || pageTitle;
      if (contentDescription) contentDescription.textContent = '';
      
      if (contentBody) {
        const html = data.parse?.text?.['*'] || '';
        contentBody.innerHTML = html;
        
        contentBody.querySelectorAll('sup, .reference, .references, .reflist, .reference-list, .cite, .reference-icon, .footnote, .footnotes, .noprint, .mw-editsection, .catlinks, .printfooter, .navbox, .sidebar, .infobox, .vertical-navbox, .navbox-group, .sistersitebox, .mw-empty-elt, img, .thumb, .gallery, .mw-file-element, table:not(.wikitable)').forEach(el => el.remove());
        contentBody.querySelectorAll('table').forEach(table => {
          if (!table.classList.contains('wikitable')) {
            table.remove();
          }
        });
        contentBody.querySelectorAll('a').forEach(a => {
          const href = a.getAttribute('href') || '';
          if (href.startsWith('#') || href.includes('cite')) {
            a.remove();
          } else {
            a.setAttribute('target', '_blank');
            a.setAttribute('rel', 'noopener noreferrer');
            a.classList.add('text-gray-700', 'hover:underline');
          }
        });
        contentBody.querySelectorAll('table').forEach(table => {
          table.classList.add('w-full', 'border-collapse', 'my-4');
          table.querySelectorAll('th, td').forEach(cell => {
            cell.classList.add('border', 'border-gray-300', 'px-3', 'py-2');
          });
        });
        contentBody.querySelectorAll('h1, h2, h3, h4, h5, h6').forEach(h => {
          h.classList.add('text-gray-900', 'font-bold', 'mt-6', 'mb-3');
        });
        contentBody.querySelectorAll('p').forEach(p => {
          p.classList.add('mb-4');
        });
      }
      
      content?.classList.remove('hidden');
    } catch (err) {
      console.error(err);
      showError('Failed to fetch Wikipedia content. Please check the URL.');
    } finally {
      loading?.classList.add('hidden');
      btn.disabled = false;
    }
  }

  async function handleLoadPdf() {
    const file = pdfInput.files?.[0];
    
    if (!file) {
      showError('Please select a PDF file');
      return;
    }

    if (file.type !== 'application/pdf') {
      showError('Please select a valid PDF file');
      return;
    }

    hideError();
    content?.classList.add('hidden');
    loading?.classList.remove('hidden');
    pdfBtn.disabled = true;

    try {
      const arrayBuffer = await file.arrayBuffer();
      
      const pdf = await getDocument({ data: arrayBuffer }).promise;
      
      let fullText = '';
      
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const textContent = await page.getTextContent();
        const viewport = page.getViewport({ scale: 1 });
        
        const lines = [];
        let currentLine = { y: -1, items: [] };
        
        for (const item of textContent.items) {
          const text = item.str;
          if (!text.trim()) continue;
          
          const x = item.transform[4];
          const y = viewport.height - item.transform[5];
          
          if (currentLine.y === -1) {
            currentLine = { y, items: [{ text, x }] };
          } else if (Math.abs(y - currentLine.y) < 5) {
            currentLine.items.push({ text, x });
            currentLine.items.sort((a, b) => a.x - b.x);
          } else {
            if (currentLine.items.length > 0) lines.push(currentLine);
            currentLine = { y, items: [{ text, x }] };
          }
        }
        if (currentLine.items.length > 0) lines.push(currentLine);
        
        let lastY = -1;
        for (const line of lines) {
          const lineText = line.items.map(item => item.text).join(' ');
          if (lastY !== -1 && Math.abs(line.y - lastY) > 12) {
            fullText += '<br/><br/>';
          }
          fullText += `<p>${lineText}</p>`;
          lastY = line.y;
        }
        fullText += '<br/><br/>';
      }
      
      console.log('PDF Content:', fullText);

      if (contentTitle) contentTitle.textContent = file.name.replace('.pdf', '');
      if (contentDescription) contentDescription.textContent = `${pdf.numPages} page(s)`;
      
      if (contentBody) {
        contentBody.innerHTML = fullText;
      }

      content?.classList.remove('hidden');
    } catch (err) {
      console.error(err);
      showError('Failed to load PDF. Please try another file.');
    } finally {
      loading?.classList.add('hidden');
      pdfBtn.disabled = false;
    }
  }

  function startSpeechRecognition() {
    if (!speechRecognition) {
      showError('Speech recognition not supported in this browser');
      return;
    }

    try {
      speechRecognition.start();
      speechPlayBtn.disabled = true;
      speechStopBtn.disabled = false;
    } catch (err) {
      console.error('Failed to start speech recognition:', err);
    }
  }

  function stopSpeechRecognition() {
    if (speechRecognition) {
      speechRecognition.stop();
      speechPlayBtn.disabled = false;
      speechStopBtn.disabled = true;
    }
  }

  function showError(msg) {
    if (error) {
      error.textContent = msg;
      error.classList.remove('hidden');
    }
  }

  function hideError() {
    if (error) {
      error.classList.add('hidden');
    }
  }

  btn?.addEventListener('click', fetchWikiContent);
  input?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') fetchWikiContent();
  });
  
  pdfBtn?.addEventListener('click', handleLoadPdf);
  
  speechPlayBtn?.addEventListener('click', startSpeechRecognition);
  speechStopBtn?.addEventListener('click', stopSpeechRecognition);
</script>
